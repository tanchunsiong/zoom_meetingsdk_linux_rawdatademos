IMAGE=dcr.asdc.cc/zoom-sendraw-loadtest-meeting:latest

MEETING_MODE=join
MEETING_NUMBER=1234567890
JWT_TOKEN=
MEETING_PASSWORD=
USER_ZAK=
ZOOM_USERNAME_PREFIX=LoadBot
MEDIA_MANIFEST=../media/manifest.json
MEDIA_INDEX=-1

JWT_ENDPOINT=https://nodejs.asdc.cc/meeting
USE_JWT_TOKEN_FROM_WEB_SERVICE=false
USE_RECORDING_TOKEN_FROM_WEB_SERVICE=false

SEND_VIDEO_RAW_DATA=true
SEND_AUDIO_RAW_DATA=true
CHAT_DEMO=true
EXIT_ON_MEETING_END=true

VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30
AUDIO_SAMPLE_RATE=48000
AUDIO_CHANNELS=1

CPU_MIN=0.25
CPU_MAX=0.5
MEMORY_MIN=200m
MEMORY_MAX=500m
SHM_SIZE=256m
RESTART_POLICY=no
PROJECT=zoom-loadtest-meeting
